<?php

/************************************************************
 * ACF BACKEND SETUP
 * ----------------------------------------------------------
 * Yaha hum:
 * 1. Required files include kar rahe hain
 * 2. Flexible Content register kar rahe hain
 * 3. Layouts load kar rahe hain
 ************************************************************/


/**
 * Common Functions File
 */
require get_template_directory() . '/inc/controllers/function.php';


/**
 * ACF Components Register File
 */
require get_template_directory() . '/acf/register-page-components.php';



/************************************************************
 * LOAD LAYOUT FILES
 * ----------------------------------------------------------
 * Har component ka ek alag layout file hoga.
 * Example:
 * banner.php
 * hero.php
 * faq.php
 ************************************************************/

/**
 * Banner Layout Load Function
 */
function get_layout_banner()
{
    return include get_template_directory() . '/acf/layouts/banner.php';
}




/************************************************************
 * REGISTER FLEXIBLE CONTENT FIELD
 * ----------------------------------------------------------
 * Ye ACF Flexible Content create karega
 * jisme multiple components add kar sakte hain.
 ************************************************************/

add_action('acf/init', function () {

    acf_add_local_field_group([

        // Group unique key
        'key' => 'group_page_components',

        // Backend title
        'title' => 'Components',

        // All fields
        'fields' => [

            [
                // Flexible content field key
                'key' => 'field_page_components',

                // Backend label
                'label' => 'Components',

                // Field name
                'name' => 'page_components',

                // Flexible content type
                'type' => 'flexible_content',

                // Add layout button text
                'button_label' => 'Add Component',

                // All layouts
                'layouts' => [

                    // Banner Layout
                    get_layout_banner(),

                ]
            ]

        ],



        /********************************************************
         * LOCATION RULE
         * ------------------------------------------------------
         * Ye sirf Pages ke andar show hoga.
         ********************************************************/
        'location' => [
            [
                [
                    'param' => 'post_type',
                    'operator' => '==',
                    'value' => 'page',
                ],
            ],
        ],



        /********************************************************
         * UI SETTINGS
         ********************************************************/
        'style' => 'default',
        'position' => 'normal',
        'menu_order' => 0,

    ]);
});




