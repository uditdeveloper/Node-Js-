<?php

/**
 * Hide Section Check
 * --------------------------------------------------
 * Agar backend me hide_section ON hai
 * toh ye component render nahi hoga
 */
if (get_sub_field('hide_section')) {
    return;
}

?>


<section

    <!-- Dynamic CSS Classes -->
    class="hero-slider <?php echo esc_attr(get_sub_field('css_class')); ?>"

    <!-- Dynamic Section ID -->
    id="<?php echo esc_attr(get_sub_field('section_id')); ?>"
>

    <div class="container">


        <?php if (get_sub_field('title')) : ?>

            <!-- Banner Title -->
            <h2 class="hero-slider__title">

                <?php echo esc_html(get_sub_field('title')); ?>

            </h2>

        <?php endif; ?>



        <?php if (get_sub_field('description')) : ?>

            <!-- Banner Description -->
            <div class="hero-slider__description">

                <?php echo wp_kses_post(get_sub_field('description')); ?>

            </div>

        <?php endif; ?>


    </div>

</section>


Page Template Display

📁 page.php


<?php
/**
 * Template Name: Default Page
 * --------------------------------------------------
 * Ye file sab pages render karegi
 */

get_header();
?>



<?php

/**
 * Flexible Content Loop
 * --------------------------------------------------
 * Har component ko loop me load karega
 */

if (have_rows('page_components')) :

    while (have_rows('page_components')) :

        the_row();

        /**
         * Current Layout Name
         * Example:
         * banner
         * faq
         * hero
         */
        $layout = get_row_layout();



        /**
         * Dynamic Component Load
         * ------------------------------------------------
         * Ye automatically matching file load karega
         *
         * Example:
         * banner => banner.php
         */
        get_template_part(
            'template-parts/components/' . $layout
        );

    endwhile;

endif;

?>



<?php get_footer(); ?>


